@model IEnumerable<AuctionViewModel>
@{
    ViewData["Title"] = "Auctions";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <div>
        <h2 class="mb-1">Auctions</h2>
        <p class="text-muted mb-0">Browse active and closed listings.</p>
    </div>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a asp-action="Create" class="btn btn-primary">Create Auction</a>
    }
</div>

<div class="row g-4">
    @foreach (var auction in Model)
    {
        var isOpen = auction.IsActive && auction.EndTime > DateTime.UtcNow;
        <div class="col-md-6 col-xl-4">
            <div class="card auction-card shadow-sm h-100">
                <div class="card-body d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h5 class="card-title mb-0">@auction.Title</h5>
                        <span class="badge @(isOpen ? "bg-success" : "bg-secondary")">@(isOpen ? "Active" : "Ended")</span>
                    </div>

                    <div class="countdown small text-muted mb-3" data-end="@auction.EndTime.ToString("o")">Loading...</div>

                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Current price</span>
                        <strong>@auction.CurrentPrice.ToString("C")</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Bid step</span>
                        <span>@auction.BidStep.ToString("C")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">Bids</span>
                        <span class="badge text-bg-light">@auction.BidsCount</span>
                    </div>

                    <div class="mt-auto d-flex gap-2">
                        <a asp-action="Details" asp-route-id="@auction.Id" class="btn btn-outline-primary btn-sm">Details</a>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a asp-action="Edit" asp-route-id="@auction.Id" class="btn btn-outline-warning btn-sm">Edit</a>
                            <a asp-action="Delete" asp-route-id="@auction.Id" class="btn btn-outline-danger btn-sm">Delete</a>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>
