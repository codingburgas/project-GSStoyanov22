@model AuctionViewModel
@{
    ViewData["Title"] = "Delete Auction";
}

<h2 class="mb-3 text-danger">Delete Auction</h2>

<div class="alert alert-warning">
    You are about to delete <strong>@Model.Title</strong>. This action cannot be undone.
</div>

<dl class="row mb-4">
    <dt class="col-sm-3">Current Price</dt>
    <dd class="col-sm-9">@Model.CurrentPrice.ToString("C")</dd>
    <dt class="col-sm-3">End Time</dt>
    <dd class="col-sm-9">@Model.EndTime.ToString("yyyy-MM-dd HH:mm") UTC</dd>
</dl>

<form asp-action="Delete" method="post" class="d-flex gap-2">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
</form>
