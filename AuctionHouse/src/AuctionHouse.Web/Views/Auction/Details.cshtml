@model AuctionDetailsViewModel
@{
    ViewData["Title"] = "Auction Details";
    var isOpen = Model.IsActive && Model.EndTime > DateTime.UtcNow;
}

<div class="auction-header mb-4">
    <div>
        <h2 class="mb-1">@Model.Title</h2>
        <span class="badge @(isOpen ? "bg-success" : "bg-secondary")">@(isOpen ? "Active" : "Auction Ended")</span>
    </div>
    <div class="countdown-wrap text-end">
        <div class="small text-muted">Time remaining</div>
        <div class="countdown" data-end="@Model.EndTime.ToString("o")">Loading...</div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <p class="mb-3">@Model.Description</p>
                <div class="row g-3">
                    <div class="col-sm-6">
                        <div class="stat-card">
                            <span class="stat-label">Starting Price</span>
                            <div class="stat-value">@Model.StartingPrice.ToString("C")</div>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="stat-card">
                            <span class="stat-label">Current Price</span>
                            <div class="stat-value">@Model.CurrentPrice.ToString("C")</div>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="stat-card">
                            <span class="stat-label">Bid Step</span>
                            <div class="stat-value">@Model.BidStep.ToString("C")</div>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="stat-card">
                            <span class="stat-label">Total Bids</span>
                            <div class="stat-value">@Model.BidsCount</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        @if (User.Identity?.IsAuthenticated == true && isOpen)
        {
            <form asp-controller="Bid" asp-action="PlaceBid" method="post" class="card card-body shadow-sm mb-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="AuctionId" value="@Model.Id" />
                <label class="form-label fw-semibold">Place bid</label>
                <input name="Amount" type="number" step="0.01" min="@(Model.CurrentPrice + Model.BidStep)" class="form-control mb-2" required />
                <div class="form-text mb-3">Minimum next bid: @((Model.CurrentPrice + Model.BidStep).ToString("C"))</div>
                <button type="submit" class="btn btn-success">Place Bid</button>
            </form>
        }
        else if (!isOpen)
        {
            <div class="alert alert-secondary">Auction Ended</div>
        }

        <div class="card shadow-sm">
            <div class="card-header fw-semibold">Bid History</div>
            <div class="card-body p-0">
                @if (!Model.BidHistory.Any())
                {
                    <p class="p-3 mb-0 text-muted">No bids yet.</p>
                }
                else
                {
                    <ul class="list-group list-group-flush bid-history-list">
                        @foreach (var bid in Model.BidHistory)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-start">
                                <div>
                                    <div class="fw-semibold">@bid.Bidder</div>
                                    <small class="text-muted">@bid.Time.ToString("yyyy-MM-dd HH:mm:ss") UTC</small>
                                </div>
                                <span class="badge bg-primary rounded-pill">@bid.Amount.ToString("C")</span>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>

<a asp-action="Index" class="btn btn-outline-secondary mt-4">Back to List</a>
